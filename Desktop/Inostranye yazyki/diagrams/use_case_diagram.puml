@startuml LinguaAI_Use_Case_Diagram
!theme plain
skinparam shadowing false
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Arial
skinparam defaultFontSize 10

title LinguaAI — Диаграмма прецедентов (Use Case Diagram)

' ==================== АКТОРЫ ====================
:Гость: as Guest
:Ученик: as Student
:Менеджер: as Manager
:Администратор: as Admin
actor "ИИ-Система" as AI

' ==================== ГРАНИЦА СИСТЕМЫ ====================
rectangle "«система» LinguaAI" {

  ' ==================== АУТЕНТИФИКАЦИЯ ====================
  package "Аутентификация" #E3F2FD {
    usecase "Зарегистрироваться" as UCф1
    usecase "Войти в систему" as UC2
    usecase "Выйти из системы" as UC3
    usecase "Редактировать профиль" as UC4
  }

  ' ==================== СЛОВАРИ ====================
  package "Управление словарями" #FFF9E6 {
    usecase "Создать словарь" as UC5
    usecase "Добавить слово" as UC6
    usecase "Удалить слово/словарь" as UC7
    usecase "Поиск и фильтр словарей" as UC8
    usecase "Экспорт CSV/JSON" as UC9
  }

  ' ==================== ОБУЧЕНИЕ ====================
  package "Обучение" #E8F5E9 {
    usecase "Просматривать карточки" as UC10
    usecase "Режим изучения (SM-2)" as UC11
    usecase "Пройти тест (4 варианта)" as UC12
    usecase "Режим сопоставления" as UC13
    usecase "Speed Round (таймер)" as UC14
    usecase "Прослушать слово (TTS)" as UC15
    usecase "Использовать\nгорячие клавиши" as UC16
  }

  ' ==================== ИИ ====================
  package "ИИ-функции" #F3E5F5 {
    usecase "Чат с ИИ-тьютором" as UC17
    usecase "Получить рекомендации" as UC18
    usecase "Получить совет дня" as UC19
    usecase "Адаптивный подбор уровня" as UC20
    usecase "Расчёт интервалов SM-2" as UC21
  }

  ' ==================== ПРОГРЕСС ====================
  package "Прогресс и геймификация" #FFEBEE {
    usecase "Просмотр прогресса" as UC22
    usecase "Получать XP за занятия" as UC23
    usecase "Поддерживать серию (streak)" as UC24
    usecase "Получать достижения" as UC25
    usecase "Просмотр таблицы лидеров" as UC26
    usecase "Получать уведомления" as UC27
  }

  ' ==================== НАСТРОЙКИ ====================
  package "Настройки" #F5F5F5 {
    usecase "Сменить тему\n(темная/светлая)" as UC28
    usecase "Добавить язык обучения" as UC29
    usecase "Глобальный поиск\nпо разделам" as UC30
    usecase "Сбросить прогресс" as UC31
  }

  ' ==================== АДМИНИСТРИРОВАНИЕ ====================
  package "Администрирование" #E3F2FD {
    usecase "Просмотр списка\nпользователей" as UC32
    usecase "Изменить роль\nпользователя" as UC33
    usecase "Заблокировать\nпользователя" as UC34
    usecase "Удалить пользователя" as UC35
    usecase "Просмотр статистики\nсистемы" as UC36
    usecase "Очистить данные\nобучения" as UC37
  }
}

' ==================== СВЯЗИ: ГОСТЬ ====================
Guest --> UC1
Guest --> UC2

' ==================== СВЯЗИ: УЧЕНИК ====================
Student --> UC10
Student --> UC11
Student --> UC12
Student --> UC13
Student --> UC14
Student --> UC15
Student --> UC5
Student --> UC6
Student --> UC9
Student --> UC22
Student --> UC17
Student --> UC28
Student --> UC26

' ==================== СВЯЗИ: МЕНЕДЖЕР ====================
Manager --> UC32
Manager --> UC34
Manager --> UC36

' ==================== СВЯЗИ: АДМИНИСТРАТОР ====================
Admin --> UC33
Admin --> UC35
Admin --> UC37

' ==================== СВЯЗИ: ИИ-СИСТЕМА ====================
AI --> UC18
AI --> UC21
AI --> UC20
AI --> UC19

' ==================== НАСЛЕДОВАНИЕ АКТОРОВ ====================
Student --|> Guest : <<extends>>
Manager --|> Student : <<extends>>
Admin --|> Manager : <<extends>>

' ==================== СВЯЗИ «INCLUDE» ====================
UC11 ..> UC21 : <<include>>
UC10 ..> UC15 : <<include>>
UC11 ..> UC23 : <<include>>
UC14 ..> UC24 : <<include>>
UC13 ..> UC25 : <<include>>
UC5 ..> UC6 : <<include>>

' ==================== СВЯЗИ «EXTEND» ====================
UC9 ..> UC5 : <<extend>>
UC16 ..> UC10 : <<extend>>
UC27 ..> UC25 : <<extend>>

note right of AI
  ИИ-система автоматически
  предоставляет рекомендации,
  рассчитывает интервалы SM-2
  и адаптирует сложность
end note

note bottom of Admin
  **Всего прецедентов:** 37
  **Акторов:** 5
  **Наследование:** 3 уровня
end note

@enduml
