@startuml LinguaAI_Database_Schema
!theme plain
skinparam shadowing false
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam entity {
  BorderColor #555555
  BackgroundColor #F8F9FF
  HeaderBackgroundColor #6366F1
  HeaderFontColor #FFFFFF
  FontSize 11
}
skinparam ArrowColor #555555

title LinguaAI — Схема базы данных (ER-диаграмма)

' ==================== ТАБЛИЦЫ ====================

entity "users" as users {
  * id : STRING <<PK>>
  --
  * name : STRING
  * email : STRING <<UNIQUE>>
  * passwordHash : STRING
  * role : ENUM(user|manager|admin)
  * createdAt : DATETIME
    streak : INT = 0
    lastStudyDate : DATE
    nativeLanguage : STRING
}

entity "learning_languages" as lang {
  * id : STRING <<PK>>
  --
  * userId : STRING <<FK>>
  * language : STRING
    xp : INT = 0
    level : ENUM(beginner|elementary|...)
    wordsLearned : INT = 0
    accuracy : FLOAT = 0
}

entity "study_sessions" as sessions {
  * id : STRING <<PK>>
  --
  * userId : STRING <<FK>>
  * languageId : STRING <<FK>>
  * date : DATE
    cardsStudied : INT
    correctAnswers : INT
    duration : INT
    xpEarned : INT
}

entity "dictionaries" as dicts {
  * id : STRING <<PK>>
  --
  * userId : STRING <<FK>>
  * name : STRING
  * language : STRING
  * nativeLanguage : STRING
    level : ENUM(beginner|...)
    isPublic : BOOLEAN = false
    coverColor : STRING
    tags : JSON
    createdAt : DATETIME
}

entity "words" as words {
  * id : STRING <<PK>>
  --
  * dictionaryId : STRING <<FK>>
  * term : STRING
  * translation : STRING
  * language : STRING
    phonetic : STRING
    partOfSpeech : STRING
    examples : JSON
    tags : JSON
    difficulty : ENUM(beginner|...)
}

entity "flashcards" as flashcards {
  * id : STRING <<PK>>
  --
  * wordId : STRING <<FK>>
  * userId : STRING <<FK>>
    status : ENUM(new|learning|review|mastered)
    interval : INT = 1
    easeFactor : FLOAT = 2.5
    repetitions : INT = 0
    nextReviewDate : DATE
    correctCount : INT = 0
    incorrectCount : INT = 0
    lastReviewedAt : DATETIME
}

entity "achievements" as achievements {
  * id : STRING <<PK>>
  --
  * name : STRING
  * description : STRING
  * icon : STRING
  * category : STRING
    condition : JSON
    xpReward : INT
}

entity "user_achievements" as user_ach {
  * id : STRING <<PK>>
  --
  * userId : STRING <<FK>>
  * achievementId : STRING <<FK>>
  * unlockedAt : DATETIME
}

entity "ai_chat_messages" as ai_chat {
  * id : STRING <<PK>>
  --
  * userId : STRING <<FK>>
  * role : ENUM(user|assistant)
  * content : TEXT
  * language : STRING
  * createdAt : DATETIME
}

' ==================== СВЯЗИ ====================

users ||--o{ learning_languages : "изучает\n(1..N)"
users ||--o{ study_sessions : "проводит\n(1..N)"
users ||--o{ dictionaries : "создаёт\n(1..N)"
users ||--o{ flashcards : "учит\n(1..N)"
users ||--o{ user_achievements : "получает\n(1..N)"
users ||--o{ ai_chat : "общается\n(1..N)"

dictionaries ||--o{ words : "содержит\n(1..N)"
words ||--|| flashcards : "имеет карточку\n(1..1)"

achievements ||--o{ user_achievements : "присваивается\n(1..N)"

learning_languages ||--o{ study_sessions : "входит в\n(1..N)"

@enduml
